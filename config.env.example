# Скопируйте в config.env и заполните (файл не коммитится)
# Паттерн: ../scinikel/config.env — ProxyAPI для Gemini Vision

# --- LLM Arbitrator (спорные кейсы сортировки, оценка crop с ленты) ---
# Ключ ProxyAPI (тот же, что для OpenAI-шлюза, если GEMINI_API_KEY пуст)
OPENAI_API_KEY=your_proxyapi_key_here

# Gemini через ProxyAPI (арбитр смотрит на картинку посылки)
# Документация моделей: https://proxyapi.ru/docs/google-models
# gemini-3.5-flash — ввод: текст/изображение, лимит ~30k RPM (см. тариф ProxyAPI)

GEMINI_API_KEY=
GEMINI_BASE_URL=https://api.proxyapi.ru/google
GEMINI_MODEL=gemini-3.5-flash
# fallback в коде: gemini-3.1-flash-preview → gemini-3-flash-preview → gemini-2.5-flash
GEMINI_TIMEOUT=60

# Опционально: OpenAI-совместимый fallback (текст без vision)
# OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
# OPENAI_MODEL=gpt-4o-mini

# Включить арбитра в рантайме: config/pipeline.yaml → arbitrator.enabled: true
